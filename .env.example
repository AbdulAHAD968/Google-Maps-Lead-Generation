# MongoDB connection string (Atlas or self-hosted)
MONGODB_URI=

# Google Maps Platform API key (server-side).
# Needs: Places API (New), Geocoding API
GOOGLE_MAPS_API_KEY=

# Same Google Maps key, exposed to the browser for rendering the map
# (Maps JavaScript API). Restrict this one by HTTP referrer in the
# Google Cloud Console since it will be visible in page source.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# OpenAI API key, used to generate personalized outreach messages
# (email / DM / LinkedIn) from the Lead Manager
OPENAI_API_KEY=
